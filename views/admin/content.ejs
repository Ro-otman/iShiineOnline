<%- include('partials/layout-start') %>

<section class="content-grid-2 content-layout">
  <article class="panel form-panel content-form-panel">
    <div class="section-head content-section-head">
      <div>
        <p class="eyebrow"><i class='bx bx-edit'></i> Création</p>
        <h3><i class='bx bx-message-square-add'></i> Ajouter un quiz</h3>
      </div>
      <span class="soft-badge"><i class='bx bx-book-content'></i> <%= helpers.number(data.programmes.length) %> programmes</span>
    </div>

    <form method="post" action="/admin/content/quiz" class="quiz-form">
      <label class="content-field">
        <span class="content-field-label"><i class='bx bx-library'></i> Programme</span>
        <select name="id_programme" required>
          <option value="">Sélectionner un programme</option>
          <% data.programmes.forEach((programme) => { %>
            <option value="<%= programme.id_programme %>" <%= String(form.id_programme || '') === String(programme.id_programme) ? 'selected' : '' %>><%= programme.label %> (<%= programme.quiz_count %> quiz)</option>
          <% }) %>
        </select>
      </label>

      <label class="content-field">
        <span class="content-field-label"><i class='bx bx-folder-open'></i> Chapitre / SA</span>
        <input type="text" name="sa_name" value="<%= form.sa_name || '' %>" placeholder="Ex : Fonctions affines" required />
      </label>

      <div class="form-split">
        <label class="content-field">
          <span class="content-field-label"><i class='bx bx-signal-4'></i> Difficulté</span>
          <select name="difficulty">
            <% ['facile', 'moyen', 'difficile'].forEach((level) => { %>
              <option value="<%= level %>" <%= String(form.difficulty || 'moyen') === level ? 'selected' : '' %>><%= level %></option>
            <% }) %>
          </select>
        </label>
        <label class="content-field">
          <span class="content-field-label"><i class='bx bx-timer'></i> Minuteur (secondes)</span>
          <input type="number" name="timer_seconds" min="10" max="600" step="10" value="<%= form.timer_seconds || '' %>" placeholder="Ex : 20, 30, 40, 60, 80" required />
        </label>
      </div>

      <label class="content-field">
        <span class="content-field-label"><i class='bx bx-help-circle'></i> Question</span>
        <textarea name="question" rows="4" placeholder="Écris ici la question complète" required><%= form.question || '' %></textarea>
      </label>

      <div class="options-grid">
        <% const optionKeys = ['a', 'b', 'c', 'd']; %>
        <% const optionLabels = ['Option A', 'Option B', 'Option C', 'Option D']; %>
        <% optionKeys.forEach((key, index) => { %>
          <label class="option-card content-option-card">
            <div class="option-topline content-option-topline">
              <span class="content-option-title"><i class='bx bx-radio-circle-marked'></i> <%= optionLabels[index] %></span>
              <span class="radio-wrap"><input type="radio" name="correct_option" value="<%= index %>" <%= String(form.correct_option || '0') === String(index) ? 'checked' : '' %> /><small>Bonne réponse</small></span>
            </div>
            <input type="text" name="option_<%= key %>" value="<%= form[`option_${key}`] || '' %>" required />
          </label>
        <% }) %>
      </div>

      <div class="form-split form-split-large">
        <label class="content-field"><span class="content-field-label"><i class='bx bx-detail'></i> Explication</span><textarea name="explanation" rows="4" placeholder="Pourquoi la bonne réponse est correcte ?"><%= form.explanation || '' %></textarea></label>
        <label class="content-field"><span class="content-field-label"><i class='bx bx-bulb'></i> Astuce</span><textarea name="tip" rows="4" placeholder="Petit indice à montrer à l’apprenant"><%= form.tip || '' %></textarea></label>
      </div>

      <button type="submit" class="primary-button"><i class='bx bx-send'></i> Publier le quiz</button>
    </form>
  </article>

  <div class="panel-stack content-side-stack">
    <article class="panel panel-content-subjects">
      <div class="section-head content-section-head">
        <div>
          <p class="eyebrow"><i class='bx bx-book-reader'></i> Matières</p>
          <h3><i class='bx bx-bar-chart-alt-2'></i> Les plus fournies</h3>
        </div>
      </div>
      <div class="mini-list content-subject-list">
        <% data.subjectBreakdown.forEach((item, index) => { %>
          <div class="mini-row content-subject-row">
            <div class="content-subject-main">
              <span class="content-subject-rank"><i class='bx bx-hash'></i> <%= index + 1 %></span>
              <div class="content-subject-copy">
                <strong><%= item.nom_matiere %></strong>
                <small><%= helpers.number(item.sa_count) %> chapitres</small>
              </div>
            </div>
            <span class="count-badge content-subject-badge"><i class='bx bx-check-shield'></i> <%= helpers.number(item.quiz_count) %> quiz</span>
          </div>
        <% }) %>
      </div>
    </article>
  </div>
</section>

<%- include('partials/layout-end') %>
