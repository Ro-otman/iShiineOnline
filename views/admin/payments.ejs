<%- include('partials/layout-start') %>

<section class="hero-band payments-hero">
  <div class="hero-copy">
    <p class="eyebrow">Journal détaillé</p>
    <h3>Suivi des paiements FedaPay</h3>
  </div>

  <div class="hero-badges">
    <span class="soft-badge"><i class="bx bx-check-double"></i> <%= helpers.number(data.paymentMetrics.successfulPayments) %> validé(s)</span>
    <span class="soft-badge"><i class="bx bx-loader-circle"></i> <%= helpers.number(data.paymentMetrics.pendingPayments) %> en attente</span>
    <span class="soft-badge"><i class="bx bx-transfer"></i> <%= helpers.money(data.paymentMetrics.transferredRevenue) %> F CFA transférés</span>
  </div>
</section>

<section class="metric-grid metric-grid-4">
  <article class="metric-card panel metric-with-icon accent-gold">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-gold"><i class="bx bxs-bank"></i></div>
      <span class="metric-label">CA confirmé</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.money(data.paymentMetrics.grossRevenue) %></strong>
      <span class="metric-help">Transactions approuvées ou transférées</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-sky">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-blue"><i class="bx bx-transfer-alt"></i></div>
      <span class="metric-label">Montant transféré</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.money(data.paymentMetrics.transferredRevenue) %></strong>
      <span class="metric-help">Versé sur la balance FedaPay</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-coral">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-coral"><i class="bx bx-calendar-event"></i></div>
      <span class="metric-label">CA du mois</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.money(data.paymentMetrics.monthRevenue) %></strong>
      <span class="metric-help">Mois courant</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-mint">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-mint"><i class="bx bxs-credit-card-front"></i></div>
      <span class="metric-label">Transactions</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.number(data.paymentMetrics.totalPayments) %></strong>
      <span class="metric-help">Journal du backend</span>
    </div>
  </article>
</section>

<section class="content-grid-2 payments-layout">
  <article class="panel wide-panel panel-payments-table">
    <div class="section-head">
      <div>
        <p class="eyebrow">Flux récents</p>
        <h3>Derniers paiements</h3>
      </div>
      <span class="soft-badge"><i class="bx bx-receipt"></i> <%= helpers.number(data.paymentMetrics.totalPayments) %> transaction(s)</span>
    </div>

    <div class="table-wrap payments-table-wrap">
      <table>
        <thead>
          <tr>
            <th>Transaction</th>
            <th>Utilisateur</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Maj provider</th>
          </tr>
        </thead>
        <tbody>
          <% if (!data.recentPayments.length) { %>
            <tr><td colspan="5">Aucune transaction enregistrée pour le moment.</td></tr>
          <% } %>
          <% data.recentPayments.forEach((payment) => { %>
            <% const displayName = `${payment.prenoms || payment.customer_firstname || ''} ${payment.nom || payment.customer_lastname || ''}`.trim() || 'Utilisateur inconnu'; %>
            <% const displayEmail = payment.user_email || payment.customer_email || payment.customer_phone || 'Aucun contact'; %>
            <% const updatedAt = payment.provider_updated_at || payment.updated_at || payment.created_at; %>
            <tr>
              <td>
                <strong><%= payment.transaction_id %></strong>
                <small><%= payment.plan_key || 'premium_monthly' %></small>
              </td>
              <td>
                <strong><%= displayName %></strong>
                <small><%= displayEmail %></small>
              </td>
              <td>
                <strong><%= helpers.money(payment.amount) %> <%= payment.currency_iso || 'XOF' %></strong>
                <small><%= payment.classe || 'Classe non renseignée' %></small>
              </td>
              <td>
                <span class="status-pill <%= ['approved', 'transferred'].includes(String(payment.status || '').toLowerCase()) ? 'status-pill-active' : 'status-pill-idle' %>">
                  <i class="bx <%= ['approved', 'transferred'].includes(String(payment.status || '').toLowerCase()) ? 'bx-check-shield' : 'bx-time-five' %>"></i>
                  <%= payment.status || 'inconnu' %>
                </span>
              </td>
              <td><%= helpers.dateTime(updatedAt) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel panel-note">
    <div class="section-head">
      <div>
        <p class="eyebrow">Lecture rapide</p>
        <h3>Repères</h3>
      </div>
    </div>
    <div class="note-stack">
      <div class="note-card">
        <strong>CA confirmé</strong>
        <p>Somme des transactions en statut <code>approved</code> ou <code>transferred</code>.</p>
      </div>
      <div class="note-card">
        <strong>Montant transféré</strong>
        <p>Paiements déjà passés en <code>transferred</code>.</p>
      </div>
      <div class="note-card">
        <strong>Source de vérité</strong>
        <p>Le backend consolide l’init, la vérification et le webhook dans <code>payments</code>.</p>
      </div>
    </div>
  </article>
</section>

<section class="panel panel-payments-activations">
  <div class="section-head">
    <div>
      <p class="eyebrow">Activations récentes</p>
      <h3>Derniers comptes premium</h3>
    </div>
  </div>

  <div class="table-wrap payments-activations-wrap">
    <table>
      <thead>
        <tr>
          <th>Utilisateur</th>
          <th>Classe</th>
          <th>Date début</th>
          <th>Date fin</th>
        </tr>
      </thead>
      <tbody>
        <% if (!data.recentSubscriptions.length) { %><tr><td colspan="4">Aucune activation enregistrée.</td></tr><% } %>
        <% data.recentSubscriptions.forEach((user) => { %>
          <tr>
            <td>
              <strong><%= `${user.prenoms} ${user.nom}` %></strong>
              <small><%= user.email || 'Contact non renseigné' %></small>
            </td>
            <td><%= user.classe || 'Classe non renseignée' %></td>
            <td><%= helpers.dateTime(user.subscription_date) %></td>
            <td><%= helpers.dateTime(user.subscription_expiry) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/layout-end') %>
