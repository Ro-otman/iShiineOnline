<%- include('partials/layout-start') %>

<section class="metric-grid metric-grid-3">
  <article class="metric-card panel"><span class="metric-label">Total comptes</span><strong class="metric-value"><%= helpers.number(data.metrics.totalUsers) %></strong><span class="metric-help">Base utilisateur globale</span></article>
  <article class="metric-card panel accent-sky"><span class="metric-label">Premium actifs</span><strong class="metric-value"><%= helpers.number(data.metrics.activeSubscribers) %></strong><span class="metric-help">Abonnés en cours</span></article>
  <article class="metric-card panel accent-coral"><span class="metric-label">Comptes libres</span><strong class="metric-value"><%= helpers.number(data.metrics.freeUsers) %></strong><span class="metric-help">Sans abonnement actif</span></article>
</section>

<section class="content-grid-2 users-layout">
  <article class="panel wide-panel panel-users-table">
    <div class="section-head"><div><p class="eyebrow">Base utilisateurs</p><h3>Liste récente</h3></div><span class="soft-badge"><%= helpers.number(data.users.length) %> lignes chargées</span></div>
    <div class="table-wrap users-table-wrap">
      <table>
        <thead><tr><th>Utilisateur</th><th>Classe</th><th>Statut</th><th>Échéance</th></tr></thead>
        <tbody>
          <% if (!data.users.length) { %><tr><td colspan="4">Aucun utilisateur disponible.</td></tr><% } %>
          <% data.users.forEach((user) => { %>
            <tr>
              <td><strong><%= `${user.prenoms} ${user.nom}` %></strong><small><%= user.email || user.phone || 'Contact non renseigné' %></small></td>
              <td><%= user.classe %></td>
              <td><span class="status-pill <%= Number(user.is_subscribed) === 1 ? 'status-pill-active' : 'status-pill-idle' %>"><%= Number(user.is_subscribed) === 1 ? 'Abonné' : 'Libre' %></span></td>
              <td><%= helpers.date(user.subscription_expiry) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <div class="panel-stack users-side-stack">
    <article class="panel panel-users-breakdown">
      <div class="section-head"><div><p class="eyebrow">Répartition</p><h3>Par classe</h3></div></div>
      <div class="mini-list users-class-list">
        <% data.classBreakdown.forEach((item) => { %>
          <div class="mini-row"><div><strong><%= item.classe %></strong><small>Utilisateurs inscrits</small></div><span class="count-badge"><%= helpers.number(item.total) %></span></div>
        <% }) %>
      </div>
    </article>

    <article class="panel panel-users-activations">
      <div class="section-head"><div><p class="eyebrow">Abonnéments</p><h3>Activations récentes</h3></div></div>
      <div class="stack-list users-activations-list">
        <% if (!data.recentSubscriptions.length) { %><p class="empty-copy">Aucune activation pour le moment.</p><% } %>
        <% data.recentSubscriptions.forEach((user) => { %>
          <article class="list-card"><div><strong><%= `${user.prenoms} ${user.nom}` %></strong><small><%= user.classe %></small></div><div class="list-meta"><span class="status-pill status-pill-active">Premium</span><small><%= helpers.date(user.subscription_date) %></small></div></article>
        <% }) %>
      </div>
    </article>
  </div>
</section>

<%- include('partials/layout-end') %>
